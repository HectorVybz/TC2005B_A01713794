<!doctype html>
<html lang="es">
<%- include("includes/head") %>
<body class="bg-dark text-light">
<%- include("includes/navbar") %>

<%
    const habilidadesVista = typeof habilidades !== "undefined" ? habilidades : [];
    const auditoriaVista = typeof auditoriaHabilidades !== "undefined" ? auditoriaHabilidades : [];
%>

<div class="container py-4">
    <h1><%= personaje.nombre %></h1>

    <div class="card bg-secondary text-light">
        <img src="<%= getImagePath(personaje.img) %>" class="card-img-top" alt="<%= personaje.nombre %>">
        <div class="card-body">
            <p><%= personaje.descripcion %></p>

            <h2 class="h4 mt-4">Habilidades</h2>
            <% if (habilidadesVista.length === 0) { %>
                <p class="text-light-emphasis">Este personaje todavia no tiene habilidades registradas.</p>
            <% } else { %>
                <div class="list-group mb-4">
                    <% habilidadesVista.forEach(habilidad => { %>
                        <div class="list-group-item bg-dark text-light border-secondary">
                            <h3 class="h5 mb-1"><%= habilidad.nombre %></h3>
                            <p class="mb-1"><%= habilidad.descripcion %></p>
                            <small>
                                Tipo: <%= habilidad.tipo %> |
                                Daño base: <%= habilidad.dano_base %> |
                                Energía: <%= habilidad.costo_energia %> |
                                Nivel: <%= habilidad.nivel_requerido %>
                            </small>
                        </div>
                    <% }) %>
                </div>
            <% } %>

            <h2 class="h4 mt-4">Auditoría de triggers</h2>
            <% if (auditoriaVista.length === 0) { %>
                <p class="text-light-emphasis">Aún no hay registros creados por triggers para este personaje.</p>
            <% } else { %>
                <ul class="list-group mb-4">
                    <% auditoriaVista.forEach(registro => { %>
                        <li class="list-group-item bg-dark text-light border-secondary">
                            <strong><%= registro.accion %>:</strong> <%= registro.detalle %>
                        </li>
                    <% }) %>
                </ul>
            <% } %>

            <% if (hasPermission("personajes_editar")) { %>
                <a href="/personajes/editar/<%= personaje.id %>" class="btn btn-warning">Editar personaje</a>
            <% } else if (!isAuthenticated) { %>
                <a href="/users/login" class="btn btn-outline-light">Inicia sesión para editar</a>
            <% } %>
            <a href="/personajes" class="btn btn-primary">Volver</a>
        </div>
    </div>
</div>

<%- include("includes/footer") %>
</body>
</html>
