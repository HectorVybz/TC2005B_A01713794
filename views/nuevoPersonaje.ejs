<!doctype html>
<html lang="es">
<%- include("includes/head") %>
<body class="bg-dark text-light">
<%- include("includes/navbar") %>

<div class="container py-4">
    <h1>Nuevo personaje</h1>
    <p class="text-light-emphasis">Esta ruta está protegida y solo puede usarse con una sesión autenticada.</p>

    <form action="/personajes/nuevo?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input type="text" name="nombre" class="form-control" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Imagen</label>
            <input type="file" name="img" class="form-control" accept="image/png, image/jpeg, image/webp, image/gif" required>
            <div class="form-text text-light-emphasis">Sube una imagen JPG, PNG, WEBP o GIF de maximo 2 MB.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <textarea name="descripcion" class="form-control" rows="4" required></textarea>
        </div>

        <hr>
        <h2 class="h4">Habilidad inicial</h2>
        <p class="text-light-emphasis">
            El personaje y su primera habilidad se guardan en una sola transacción.
        </p>

        <div class="mb-3">
            <label class="form-label">Nombre de la habilidad</label>
            <input type="text" name="habilidadNombre" class="form-control" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Tipo</label>
            <select name="habilidadTipo" class="form-select" required>
                <option value="Basica">Basica</option>
                <option value="Habilidad">Habilidad</option>
                <option value="Definitiva">Definitiva</option>
                <option value="Talento">Talento</option>
                <option value="Tecnica">Tecnica</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción de la habilidad</label>
            <textarea name="habilidadDescripcion" class="form-control" rows="3" required></textarea>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Daño base</label>
                <input type="number" name="danoBase" class="form-control" min="0" value="0" required>
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Costo de energía</label>
                <input type="number" name="costoEnergia" class="form-control" min="0" value="0" required>
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Nivel requerido</label>
                <input type="number" name="nivelRequerido" class="form-control" min="1" value="1" required>
            </div>
        </div>

        <button type="submit" class="btn btn-success">Guardar</button>
    </form>
</div>

<%- include("includes/footer") %>
</body>
</html>
