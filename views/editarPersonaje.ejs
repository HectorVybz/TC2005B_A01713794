<!doctype html>
<html lang="es">
<%- include("includes/head") %>
<body class="bg-dark text-light">
<%- include("includes/navbar") %>

<div class="container py-4">
    <h1>Editar personaje</h1>
    <p class="text-light-emphasis">Esta ruta está protegida y requiere autenticación.</p>

    <form action="/personajes/editar?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="id" value="<%= personaje.id %>">
        <input type="hidden" name="imgActual" value="<%= personaje.img %>">

        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input type="text" name="nombre" class="form-control" value="<%= personaje.nombre %>" required>
        </div>

        <div class="mb-3">
            <label class="form-label">Imagen actual</label>
            <div class="mb-2">
                <img src="<%= getImagePath(personaje.img) %>" class="img-thumbnail" alt="<%= personaje.nombre %>" style="max-width: 220px;">
            </div>
            <input type="file" name="img" class="form-control" accept="image/png, image/jpeg, image/webp, image/gif">
            <div class="form-text text-light-emphasis">Si no seleccionas otra imagen, se conserva la actual.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Descripción</label>
            <textarea name="descripcion" class="form-control" rows="4" required><%= personaje.descripcion %></textarea>
        </div>

        <button type="submit" class="btn btn-warning">Actualizar</button>
    </form>
</div>

<%- include("includes/footer") %>
</body>
</html>
