<!doctype html>
<html lang="es">

<%- include("includes/head") %>

<body class="bg-dark text-light">

<%- include("includes/navbar") %>

<div class="container py-4">
    <h1>Bienvenido a HSR Express</h1>

    <p>
        HSR Express es un sitio inspirado en Honkai: Star Rail, desarrollado con Express, EJS,
        arquitectura MVC, sesiones, cookies y autenticación de usuarios.
    </p>

    <% if (isAuthenticated && authUser) { %>
        <div class="alert alert-success">
            Sesión autenticada como <strong><%= authUser.username %></strong>.
        </div>
        <div class="alert alert-dark border">
            <p class="mb-1"><strong>Roles:</strong> <%= userRoles.length ? userRoles.join(", ") : "Sin roles asignados" %></p>
            <p class="mb-0"><strong>Permisos:</strong> <%= userPermissions.length ? userPermissions.join(", ") : "Sin permisos asignados" %></p>
        </div>
    <% } else if (nombreSesion) { %>
        <div class="alert alert-secondary">
            Hay una sesión activa guardada con el nombre <strong><%= nombreSesion %></strong>.
        </div>
    <% } else { %>
        <div class="alert alert-secondary">
            Aún no has iniciado sesión con un usuario registrado.
        </div>
    <% } %>

    <div class="alert alert-info">
        Personaje favorito guardado en cookie: <strong><%= personajeCookie %></strong>
    </div>

    <% if (!isAuthenticated) { %>
        <a href="/users/login" class="btn btn-primary mb-3">Iniciar sesión</a>
        <a href="/users/signup" class="btn btn-outline-light mb-3">Registrar usuario</a>
    <% } %>

    <% if (hasPermission("rbac_ver")) { %>
        <a href="/admin/rbac" class="btn btn-warning mb-3">Administrar roles y permisos</a>
    <% } %>

    <% if (isAuthenticated || nombreSesion || personajeCookie !== "No definido") { %>
        <form action="/users/logout" method="POST" class="mb-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-danger">Cerrar sesión y limpiar datos</button>
        </form>
    <% } %>

    <br>
    <img src="/images/trailblazer.webp" width="300" alt="Trailblazer" class="img-fluid rounded mt-3">
</div>

<%- include("includes/footer") %>

</body>
</html>
