<!doctype html>
<html lang="es">

<%- include("includes/head") %>

<body class="bg-dark text-light">

<%- include("includes/navbar") %>

<div class="container py-4">
    <h1>Personajes</h1>

    <div class="row">
        <% personajes.forEach(personaje => { %>
            <div class="col-md-4 mb-4">
                <div class="card bg-secondary text-light h-100">
                    <img src="/images/<%= personaje.img %>" class="card-img-top" alt="<%= personaje.nombre %>">
                    <div class="card-body">
                        <h5 class="card-title"><%= personaje.nombre %></h5>

                        <% if (personaje.nombre === "Kafka") { %>
                            <p class="card-text">
                                Kafka es una Stellaron Hunter conocida por su elegancia,
                                calma y habilidad para manipular situaciones a su favor.
                            </p>
                        <% } else if (personaje.nombre === "Acheron") { %>
                            <p class="card-text">
                                Acheron es una guerrera misteriosa con gran poder,
                                una presencia imponente y un estilo de combate letal.
                            </p>
                        <% } else if (personaje.nombre === "Jingliu") { %>
                            <p class="card-text">
                                Jingliu es una espadachina legendaria de la Xianzhou,
                                reconocida por su fuerza, disciplina y pasado trágico.
                            </p>
                        <% } else if (personaje.nombre === "Dan Heng IL") { %>
                            <p class="card-text">
                                Dan Heng Imbibitor Lunae representa una faceta poderosa
                                y ancestral, ligada a su verdadera herencia.
                            </p>
                        <% } else if (personaje.nombre === "Trailblazer") { %>
                            <p class="card-text">
                                Trailblazer es el protagonista del viaje a bordo del Astral Express,
                                explorando mundos y enfrentando amenazas estelares.
                            </p>
                        <% } %>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<%- include("includes/footer") %>

</body>
</html>